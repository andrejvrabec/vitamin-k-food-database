{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Category Schema",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "category": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "portions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "amount": { "type": "number", "minimum": 0 },
                "unit": { "type": "string", "enum": ["g", "ml", "piece", "cup", "tbsp", "tsp"] },
                "gram_equivalent": { "type": "number", "minimum": 0 },
                "vitamin_k_mcg": { "type": "number", "minimum": 0 }
              },
              "required": ["amount", "unit", "vitamin_k_mcg"],
              "if": {
                "properties": {
                  "unit": { "not": { "const": "g" } }
                }
              },
              "then": {
                "required": ["gram_equivalent"]
              }
            }
          },
          "source": { "type": "string" },
          "relations": {
            "type": "object",
            "properties": {
              "group": { "type": "string" },
              "related_ids": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["group"],
            "additionalProperties": false
          }
        },
        "required": ["id", "category", "portions"],
        "additionalProperties": false
      }
    }
  },
  "required": ["data"],
  "additionalProperties": false
}
