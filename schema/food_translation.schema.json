{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Food Translation Schema",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "name": { "type": "string" },
      "alternative_names": {
        "type": "array",
        "items": { "type": "string" }
      },
      "description": { "type": "string" }
    },
    "required": ["name", "alternative_names", "description"],
    "additionalProperties": false
  }
}
